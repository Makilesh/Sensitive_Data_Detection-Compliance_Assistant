# Copy to .env and fill in. NEVER commit the real .env.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional overrides (defaults live in src/config.py)
# SDA_ENABLE_OCR=false
# SDA_ENABLE_NER=true
# SDA_EMBEDDING_MODEL=all-MiniLM-L6-v2
# SDA_ENABLE_HYBRID_SEARCH=true   # dense (FAISS) + sparse (BM25) fused via RRF
# SDA_ENABLE_RERANKER=false       # cross-encoder reranker (better on large docs)
# SDA_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2  # CPU default
# SDA_RERANKER_MODEL_GPU=BAAI/bge-reranker-v2-m3           # used when CUDA present
# SDA_LOCAL_ONLY_MODE=false        # force local Ollama; no document text to cloud

# Local Ollama fallback (used when Gemini quota is exhausted, or with no key)
# SDA_ENABLE_OLLAMA=true
# SDA_OLLAMA_MODEL=qwen2.5:14b
# SDA_OLLAMA_HOST=http://localhost:11434
